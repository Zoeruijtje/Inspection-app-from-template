datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PropertyType {
  Residential
  Commercial
  Industrial
  Government
  Other
}

enum InspectionStatus {
  Planned
  InProgress
  Completed
  Cancelled
}

enum FormTemplateLifecycleStatus {
  ACTIVE
  ARCHIVED
}

enum FormTemplateVersionStatus {
  DRAFT
  PUBLISHED
  SUPERSEDED
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?     // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  datePaid                  DateTime?
  credits                   Int             @default(3)

  gptResponses              GptResponse[]
  contactFormMessages       ContactFormMessage[]
  tasks                     Task[]
  files                     File[]
  clients                   Client[]
  projects                  Project[]
  properties                Property[]
  inspections               Inspection[]
  formTemplates             FormTemplate[]
}

model GptResponse {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
}

model Task {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  description               String
  time                      String          @default("1")
  isDone                    Boolean         @default(false)
}

model File {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  type                      String
  s3Key                     String
}

model Client {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  email                     String?
  phone                     String?
  companyName               String?
  notes                     String?

  properties                Property[]
  inspections               Inspection[]

  @@index([userId])
}

model Property {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  client                    Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId                  String?

  address                   String
  city                      String
  postalCode                String
  type                      PropertyType    @default(Other)
  notes                     String?

  inspections               Inspection[]

  @@index([userId])
  @@index([clientId])
}

model Inspection {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  property                  Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  propertyId                String

  client                    Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId                  String?

  title                     String
  description               String?
  status                    InspectionStatus @default(Planned)
  scheduledDate             DateTime?
  completedDate             DateTime?

  @@index([userId])
  @@index([propertyId])
}

model Project {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  name      String
  notes     String?

  @@index([userId])
}

model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}

model FormTemplate {
  id                        String                        @id @default(uuid())
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  user                      User                          @relation(fields: [userId], references: [id])
  userId                    String

  name                      String                        @db.VarChar(200)
  description               String?                       @db.VarChar(2000)
  category                  String?                       @db.VarChar(120)
  tags                      String[]

  lifecycleStatus           FormTemplateLifecycleStatus   @default(ACTIVE)

  versions                  FormTemplateVersion[]

  @@index([userId])
}

model FormTemplateVersion {
  id                        String                        @id @default(uuid())
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  template                  FormTemplate                  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId                String

  versionNumber             Int
  status                    FormTemplateVersionStatus     @default(DRAFT)
  publishedAt               DateTime?

  snapshot                  Json?
  snapshotSchemaVersion     Int?
  snapshotHash              String?                       @db.VarChar(64)

  pages                     FormPageDefinition[]
  containers                FormContainerDefinition[]
  blocks                    FormBlockDefinition[]

  @@index([templateId])
  @@unique([templateId, versionNumber])
}

model FormPageDefinition {
  id                        String                        @id @default(uuid())
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  templateVersion           FormTemplateVersion           @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  templateVersionId         String

  title                     String                        @db.VarChar(200)
  sortOrder                 Int

  rootContainers            FormContainerDefinition[]

  @@index([templateVersionId])
}

model FormContainerDefinition {
  id                        String                        @id @default(uuid())
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  templateVersion           FormTemplateVersion           @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  templateVersionId         String

  containerType             String                        @db.VarChar(60)
  title                     String?                       @db.VarChar(200)
  config                    Json?
  sortOrder                 Int

  page                      FormPageDefinition?           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId                    String?

  parentContainer           FormContainerDefinition?      @relation("ContainerChildren", fields: [parentContainerId], references: [id], onDelete: Cascade)
  parentContainerId         String?

  childContainers           FormContainerDefinition[]     @relation("ContainerChildren")
  blocks                    FormBlockDefinition[]

  @@index([templateVersionId])
  @@index([pageId])
  @@index([parentContainerId])
}

model FormBlockDefinition {
  id                        String                        @id @default(uuid())
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  templateVersion           FormTemplateVersion           @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  templateVersionId         String

  blockType                 String                        @db.VarChar(60)
  blockImplementationVersion Int
  configSchemaVersion       Int
  config                    Json

  container                 FormContainerDefinition       @relation(fields: [containerId], references: [id], onDelete: Cascade)
  containerId               String

  sortOrder                 Int
  stableKey                 String                        @db.VarChar(60)
  label                     String                        @db.VarChar(200)
  required                  Boolean                       @default(false)
  conditionalVisibility     Json?
  validation                Json?

  options                   FormBlockOption[]

  @@index([templateVersionId])
  @@index([containerId])
  @@unique([templateVersionId, stableKey])
}

model FormBlockOption {
  id                        String                        @id @default(uuid())
  block                     FormBlockDefinition           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId                   String

  label                     String                        @db.VarChar(200)
  value                     String                        @db.VarChar(120)
  sortOrder                 Int

  color                     String?                       @db.VarChar(32)
  score                     Float?

  @@index([blockId])
  @@unique([blockId, value])
}
